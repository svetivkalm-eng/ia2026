import tkinter as tk
from tkinter import messagebox, ttk
import random
import json
import os

# --- 1. Список предопределённых цитат ---
# Формат: {"текст": "...", "автор": "...", "тема": "..."}
quotes_data = [
    {"текст": "Будьте тем изменением, которое вы хотите видеть в мире.", "автор": "Махатма Ганди", "тема": "Мотивация"},
    {"текст": "Жизнь — это то, что происходит с тобой, пока ты строишь другие планы.", "автор": "Джон Леннон", "тема": "Жизнь"},
    {"текст": "Единственный способ делать великие дела — любить то, что вы делаете.", "автор": "Стив Джобс", "тема": "Работа"},
    {"текст": "Успех — это не окончательно, неудача — это не фатально: мужество продолжать — вот что имеет значение.", "автор": "Уинстон Черчилль", "тема": "Успех"},
    {"текст": "Надежда — это единственная вещь, которая сильнее страха.", "автор": "Неизвестный", "тема": "Надежда"}
]

QUOTES_FILE = "quotes_history.json"

# --- Загрузка истории цитат ---
def load_history():
    if os.path.exists(QUOTES_FILE):
        try:
            with open(QUOTES_FILE, 'r', encoding='utf-8') as f:
                return json.load(f)
        except (json.JSONDecodeError, FileNotFoundError):
            return []
    return []

# --- Сохранение истории цитат ---
def save_history(history):
    with open(QUOTES_FILE, 'w', encoding='utf-8') as f:
        json.dump(history, f, ensure_ascii=False, indent=4)

# --- Главное окно ---
root = tk.Tk()
root.title("Генератор Случайных Цитат")
root.geometry("700x550")

# --- Переменные ---
current_quote_var = tk.StringVar()
history_listbox = tk.Listbox(root, width=80, height=15, font=("Arial", 10))
all_authors = sorted(list(set(q["автор"] for q in quotes_data)))
all_themes = sorted(list(set(q["тема"] for q in quotes_data)))
author_filter_var = tk.StringVar()
theme_filter_var = tk.StringVar()

# --- Функции ---
def get_random_quote():
    selected_quote = random.choice(quotes_data)
    return selected_quote

def display_quote():
    quote_info = get_random_quote()
    current_quote_var.set(f"'{quote_info['текст']}'\n- {quote_info['автор']} ({quote_info['тема']})")

    # --- 3. Отображение истории ---
    history_entry = f"'{quote_info['текст']}' - {quote_info['автор']}"
    history_listbox.insert(tk.END, history_entry)
    app_history.append(quote_info)
    save_history(app_history)

def add_quote():
    new_text = entry_new_quote_text.get().strip()
    new_author = entry_new_quote_author.get().strip()
    new_theme = entry_new_quote_theme.get().strip()

    # --- 6. Проверка корректности ввода ---
    if not new_text or not new_author or not new_theme:
        messagebox.showwarning("Внимание", "Все поля (текст, автор, тема) должны быть заполнены!")
        return

    quotes_data.append({"текст": new_text, "автор": new_author, "тема": new_theme})
    update_filter_options()
    entry_new_quote_text.delete(0, tk.END)
    entry_new_quote_author.delete(0, tk.END)
    entry_new_quote_theme.delete(0, tk.END)
    messagebox.showinfo("Успех", "Цитата успешно добавлена!")

def update_filter_options():
    global all_authors, all_themes
    all_authors = sorted(list(set(q["автор"] for q in quotes_data)))
    all_themes = sorted(list(set(q["тема"] for q in quotes_data)))

    # Обновляем значения в выпадающих списках
    author_filter_menu['values'] = ["Все"] + all_authors
    theme_filter_menu['values'] = ["Все"] + all_themes
    author_filter_var.set("Все")
    theme_filter_var.set("Все")
    filter_quotes() # Принудительно вызываем фильтрацию после добавления

def filter_quotes():
    selected_author = author_filter_var.get()
    selected_theme = theme_filter_var.get()
    filtered_quotes = quotes_data

    if selected_author != "Все":
        filtered_quotes = [q for q in filtered_quotes if q["автор"] == selected_author]
    if selected_theme != "Все":
        filtered_quotes = [q for q in filtered_quotes if q["тема"] == selected_theme]

    # Обновляем список с цитатами для отображения
    history_listbox.delete(0, tk.END)
    # Здесь мы показываем только те, которые были добавлены в историю и соответствуют фильтру.
    # Для демонстрации фильтрации, мы скорее будем перебирать оригинальные quotes_data.
    # Если надо фильтровать всю историю, то фильтруем app_history.
    # Давайте для примера, покажем исходные цитаты, если фильтр сработал
    # Чтобы было корректно, нужно иметь отдельный список для отображаемых цитат.
    # Для простоты, покажем, как отфильтровать весь набор initial quotes
    # Если бы мы хотели фильтровать именно *историю*, то логика бы шла по app_history

    # Для демонстрации фильтрации, отобразим отфильтрованные исходные цитаты
    # (это не совсем соответствует отображению ЛИСТЫ истории, но демонстрирует ИДЕЮ фильтрации)
    for quote in filtered_quotes:
        entry_text = f"'{quote['текст']}' - {quote['автор']}"
        history_listbox.insert(tk.END, entry_text)

# --- Инициализация ---
app_history = load_history()
for quote_info in app_history:
    history_listbox.insert(tk.END, f"'{quote_info['текст']}' - {quote_info['автор']}")

# --- GUI элементы ---

# Фрейм для кнопки генерации
frame_generate = tk.Frame(root, pady=10)
frame_generate.pack()

# --- 2. Кнопка "Сгенерировать цитату" ---
btn_generate = tk.Button(frame_generate, text="Сгенерировать цитату", command=display_quote, font=("Arial", 14), bg="#4CAF50", fg="white", padx=10, pady=5)
btn_generate.pack()

# --- Отображение текущей цитаты ---
quote_label = tk.Label(root, textvariable=current_quote_var, font=("Arial", 12, "italic"), wraplength=600, justify="center", pady=10)
quote_label.pack()

# --- Фрейм для фильтрации ---
frame_filter = tk.LabelFrame(root, text="Фильтр цитат", labelanchor="nw", padx=10, pady=10, font=("Arial", 11, "bold"))
frame_filter.pack(fill="x", padx=20, pady=5)

tk.Label(frame_filter, text="Автор:", font=("Arial", 10)).grid(row=0, column=0, padx=5, pady=5, sticky="w")
author_filter_var.set("Все")
author_filter_menu = ttk.Combobox(frame_filter, textvariable=author_filter_var, values=["Все"] + all_authors, state="readonly", width=27, font=("Arial", 10))
author_filter_menu.grid(row=0, column=1, padx=5, pady=5, sticky="ew")
author_filter_menu.bind("<<ComboboxSelected>>", lambda event: filter_quotes())

tk.Label(frame_filter, text="Тема:", font=("Arial", 10)).grid(row=1, column=0, padx=5, pady=5, sticky="w")
theme_filter_var.set("Все")
theme_filter_menu = ttk.Combobox(frame_filter, textvariable=theme_filter_var, values=["Все"] + all_themes, state="readonly", width=27, font=("Arial", 10))
theme_filter_menu.grid(row=1, column=1, padx=5, pady=5, sticky="ew")
theme_filter_menu.bind("<<ComboboxSelected>>", lambda event: filter_quotes())

# "Сбросить фильтр" кнопка
btn_reset_filter = tk.Button(frame_filter, text="Сбросить", command=lambda: [author_filter_var.set("Все"), theme_filter_var.set("Все"), filter_quotes()], font=("Arial", 10))
btn_reset_filter.grid(row=0, column=2, rowspan=2, padx=10, pady=5, sticky="ns")

frame_filter.columnconfigure(1, weight=1)

# --- Фрейм для добавления новых цитат ---
frame_add_quote = tk.LabelFrame(root, text="Добавить новую цитату", labelanchor="nw", padx=10, pady=10, font=("Arial", 11, "bold"))
frame_add_quote.pack(fill="x", padx=20, pady=10)

tk.Label(frame_add_quote, text="Текст:", font=("Arial", 10)).grid(row=0, column=0, padx=5, pady=5, sticky="w")
entry_new_quote_text = tk.Entry(frame_add_quote, width=40, font=("Arial", 10))
entry_new_quote_text.grid(row=0, column=1, padx=5, pady=5, sticky="ew")

tk.Label(frame_add_quote, text="Автор:", font=("Arial", 10)).grid(row=1, column=0, padx=5, pady=5, sticky="w")
entry_new_quote_author = tk.Entry(frame_add_quote, width=40, font=("Arial", 10))
entry_new_quote_author.grid(row=1, column=1, padx=5, pady=5, sticky="ew")

tk.Label(frame_add_quote, text="Тема:", font=("Arial", 10)).grid(row=2, column=0, padx=5, pady=5, sticky="w")
entry_new_quote_theme = tk.Entry(frame_add_quote, width=40, font=("Arial", 10))
entry_new_quote_theme.grid(row=2, column=1, padx=5, pady=5, sticky="ew")

btn_add_quote = tk.Button(frame_add_quote, text="Добавить", command=add_quote, font=("Arial", 10), bg="#007bff", fg="white", padx=5)
btn_add_quote.grid(row=3, column=0, columnspan=2, pady=10)

frame_add_quote.columnconfigure(1, weight=1)

# --- Список истории (теперь это поле для отображения фильтрованных цитат) ---
tk.Label(root, text="Список цитат:", font=("Arial", 11, "bold")).pack(pady=5)
# Прокрутка для списка
scrollbar = tk.Scrollbar(root, orient="vertical", command=history_listbox.yview)
scrollbar.pack(side=tk.RIGHT, fill=tk.Y)
history_listbox.config(yscrollcommand=scrollbar.set)
history_listbox.pack(pady=10, padx=20, fill=tk.BOTH, expand=True)

# --- Первая загрузка цитаты ---
display_quote() # Показываем первую цитату при запуске
filter_quotes() # Обновляем фильтры и отображаем список

root.mainloop()
